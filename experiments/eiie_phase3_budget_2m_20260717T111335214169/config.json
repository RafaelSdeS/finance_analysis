{
  "data": {
    "window": 50,
    "features": [
      "close",
      "high",
      "low"
    ],
    "window_start": "2011-01-31",
    "window_end": "2026-07-14",
    "cash_mode": "cdi"
  },
  "costs": {
    "c_sell": 0.0003,
    "c_buy": 0.0003,
    "train_mu_iters": 1,
    "backtest_mu_tol": 1e-10
  },
  "model": {
    "encoder": "eiie_cnn",
    "conv1_out_channels": 2,
    "conv2_out_channels": 20,
    "n_assets": 50
  },
  "train": {
    "lr": 3e-05,
    "l2": 1e-08,
    "batch_size": 50,
    "pretrain_steps": 2000000,
    "beta": 5e-05,
    "rolling_steps": 30,
    "grad_clip_norm": 5.0,
    "entropy_beta": 0.0001,
    "seed": 3,
    "device": "cuda",
    "compile": false
  },
  "eval": {
    "baselines": [
      "ubah",
      "ucrp",
      "best_stock",
      "random_portfolio",
      "random_rebalancing",
      "constant_cash",
      "bova11"
    ],
    "var_level": 0.95,
    "bootstrap_n": 1000,
    "bootstrap_block": 20
  },
  "experiment": {
    "name": "eiie_phase3_budget_2m",
    "out_dir": "experiments"
  }
}