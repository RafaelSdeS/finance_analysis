{
  "data": {
    "window": 50,
    "features": [
      "close",
      "high",
      "low",
      "return_1m",
      "return_3m",
      "return_6m",
      "price_vs_ma60",
      "volatility_ratio_20_60",
      "rsi_14",
      "drawdown",
      "volume_ratio_20d"
    ],
    "window_start": "2011-01-31",
    "window_end": "2026-07-14",
    "cash_mode": "cdi"
  },
  "costs": {
    "c_sell": 0.0003,
    "c_buy": 0.0003,
    "train_mu_iters": 1,
    "backtest_mu_tol": 1e-10
  },
  "model": {
    "encoder": "eiie_cnn",
    "conv1_out_channels": 16,
    "conv2_out_channels": 64,
    "n_assets": 50
  },
  "train": {
    "lr": 3e-05,
    "l2": 1e-08,
    "batch_size": 50,
    "pretrain_steps": 100000,
    "beta": 0.0005,
    "rolling_steps": 30,
    "grad_clip_norm": 5.0,
    "entropy_beta_start": 0.0001,
    "entropy_beta_end": 1e-05,
    "entropy_anneal_frac": 0.1,
    "checkpoint_holdout_days": 250,
    "checkpoint_eval_every": 5000,
    "seed": 6,
    "device": "cuda",
    "compile": false
  },
  "eval": {
    "baselines": [
      "ubah",
      "ucrp",
      "best_stock",
      "random_portfolio",
      "random_rebalancing",
      "constant_cash",
      "bova11"
    ],
    "var_level": 0.95,
    "bootstrap_n": 1000,
    "bootstrap_block": 20
  },
  "experiment": {
    "name": "eiie_capacity_e1",
    "out_dir": "experiments"
  }
}