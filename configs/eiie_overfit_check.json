{
  "data": {
    "window": 50,
    "features": ["close", "high", "low", "return_1m", "return_3m", "return_6m",
                 "price_vs_ma60", "volatility_ratio_20_60", "rsi_14", "drawdown", "volume_ratio_20d"],
    "window_start": "2022-01-03",
    "window_end": "2022-06-30",
    "cash_mode": "cdi"
  },
  "costs": {
    "c_sell": 0.0,
    "c_buy": 0.0,
    "train_mu_iters": 1,
    "backtest_mu_tol": 1e-10
  },
  "model": {
    "encoder": "eiie_cnn",
    "conv1_out_channels": 2,
    "conv2_out_channels": 20,
    "n_assets": 50
  },
  "train": {
    "lr": 3e-5,
    "l2": 1e-8,
    "batch_size": 50,
    "pretrain_steps": 100000,
    "beta": 0.0005,
    "rolling_steps": 0,
    "grad_clip_norm": 5.0,
    "entropy_beta_start": 0.0,
    "entropy_beta_end": 0.0,
    "entropy_anneal_frac": 0.0,
    "checkpoint_holdout_days": 0,
    "checkpoint_eval_every": 5000,
    "seed": 42,
    "device": "cuda",
    "compile": false
  },
  "eval": {
    "baselines": ["ucrp", "best_stock"],
    "var_level": 0.95,
    "bootstrap_n": 1000,
    "bootstrap_block": 20
  },
  "experiment": {
    "name": "eiie_overfit_check",
    "out_dir": "experiments"
  }
}
